# Appwrite Configuration
# Copy this file to .env and fill in your Appwrite credentials
# OR add these as Environment Variables in Vercel Dashboard

VITE_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_appwrite_project_id
VITE_APPWRITE_DATABASE_ID=your_appwrite_database_id
VITE_APPWRITE_MEDIA_BUCKET_ID=your_appwrite_media_bucket_id

# Brevo Email Configuration (for notifications)
VITE_BREVO_API_KEY=your_brevo_api_key
VITE_SENDER_EMAIL=yogiramsuratkumarbhajans@gmail.com
